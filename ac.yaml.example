substitutions:
  device_name: airiron-controller
  device_friendly_name: AirIron Controller

esphome:
  name: "${device_name}"
  friendly_name: "${device_friendly_name}"

esp32:
  variant: esp32c3
  framework:
    type: esp-idf

external_components:
  source: github://rndm2/esphome-panasonic-ac
  components: [panasonic_ac]

logger:

api:
  encryption:
    key: !secret airiron_controller_home_assistant_api_key

ota:
  - platform: esphome
    password: !secret airiron_controller_esp_home_password

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password

  ap:
      ssid: "AirIron-Controller"
      password: !secret airiron_ap_password

captive_portal:

web_server:
  port: 80
  auth:
    username: !secret web_login
    password: !secret web_password

uart:
  tx_pin: GPIO21
  rx_pin: GPIO20
  id: ac_uart
  baud_rate: 2400
  data_bits: 8
  parity: EVEN
  stop_bits: 1

button:
  - platform: restart
    name: "$device_friendly_name Restart"

climate:
  - platform: panasonic_ac
    id: panasonic_ac_climate
    type: wlan
    name: "$device_friendly_name"

time:
  - platform: homeassistant
    id: my_time